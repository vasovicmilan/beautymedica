<%- include('../includes/head', { title: 'Prijava' }) %>

<div class="container py-5">
  <div class="row justify-content-center">
    <div class="col-md-6 col-lg-5">
      <div class="card shadow-sm border-0 rounded-4">
        <div class="card-body p-5 text-center">
          <div class="mb-4">
            <i class="bi bi-google fs-1 text-primary"></i>
          </div>
          <h2 class="h3 mb-3">Prijava putem Google naloga</h2>
          <p class="text-muted mb-4">Za pristup našem salonu koristite svoj Google račun.</p>
          
          <% if (flash && flash.message) { %>
            <div class="alert alert-<%= flash.type === 'danger' ? 'danger' : 'success' %> alert-dismissible fade show mb-4" role="alert">
              <%= flash.message %>
              <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
            </div>
          <% } %>
          
          <a href="/auth/google" class="btn btn-primary btn-lg w-100 rounded-pill d-flex align-items-center justify-content-center gap-2">
            <i class="bi bi-google"></i> Prijavi se sa Google nalogom
          </a>
          <p class="mt-4 small text-muted">
            Korišćenjem usluge prihvatate naše uslove korišćenja i politiku privatnosti.
          </p>
        </div>
      </div>
    </div>
  </div>
</div>

<%- include('../includes/end') %>