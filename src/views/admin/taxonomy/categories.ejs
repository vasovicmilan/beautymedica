<%
  const currentUrl = '/admin/categories';
  const queryParams = { search, domain, parent };
  const totalPages = Math.ceil(total / limit);
%>

<%- include('../../includes/head', { seo }) %>
<%- include('../../includes/components/navigation') %>

<div class="container py-4">
  <div class="d-flex justify-content-between align-items-center mb-4">
    <h1 class="h2">Kategorije</h1>
    <a href="/admin/kategorije/dodavanje" class="btn btn-primary">
      <i class="bi bi-plus-circle"></i> Nova kategorija
    </a>
  </div>

  <!-- Search form -->
  <div class="card mb-4">
    <div class="card-body">
      <form action="/admin/kategorije/pretraga" method="POST" class="row g-3">
        <div class="col-md-4">
          <label for="search" class="form-label">Pretraga</label>
          <input type="text" class="form-control" id="search" name="search" value="<%= search || '' %>" placeholder="Naziv, slug...">
        </div>
        <div class="col-md-3">
          <label for="domain" class="form-label">Domen</label>
          <select class="form-select" id="domain" name="domain">
            <option value="">Svi</option>
            <option value="service" <%= (domain === 'service') ? 'selected' : '' %>>Usluge</option>
            <option value="post" <%= (domain === 'post') ? 'selected' : '' %>>Blog</option>
          </select>
        </div>
        <div class="col-md-3">
          <label for="parent" class="form-label">Parent</label>
          <select class="form-select" id="parent" name="parent">
            <option value="">Sve</option>
            <option value="null" <%= (parent === 'null') ? 'selected' : '' %>>Root kategorije</option>
          </select>
        </div>
        <div class="col-md-2 d-flex align-items-end">
          <button type="submit" class="btn btn-primary w-100">Pretraži</button>
        </div>
        <input type="hidden" name="CSRFToken" value="<%= csrfToken %>">
      </form>
    </div>
  </div>

  <!-- Tabela -->
  <div class="card">
    <div class="card-body p-0">
      <%- include('../../includes/components/table', {
        items: categories,
        actions: [
          { type: 'link', url: '/admin/kategorije/detalji/', icon: 'bi-eye', color: 'outline-info', ariaLabel: 'Detalji' },
          { type: 'link', url: '/admin/kategorije/izmena/', icon: 'bi-pencil', color: 'outline-secondary', ariaLabel: 'Izmena' },
          { type: 'form', formAction: '/admin/kategorije/brisanje/', icon: 'bi-trash', color: 'outline-danger', ariaLabel: 'Brisanje', confirm: 'Da li ste sigurni da želite da obrišete ovu kategoriju?' }
        ]
      }) %>
    </div>
  </div>

  <!-- Paginacija -->
  <% if (totalPages > 1) { %>
    <%- include('../../includes/components/pagination', {
      currentPage: page,
      totalPages: totalPages,
      baseUrl: currentUrl,
      queryParams: queryParams
    }) %>
  <% } %>
</div>

<%- include('../../includes/end') %>