<%
  if (!tag) return;
%>

<%- include('../../includes/head', { seo }) %>
<%- include('../../includes/components/navigation') %>

<div class="container py-4">
  <div class="d-flex justify-content-between align-items-center mb-4">
    <h1 class="h2">Detalji taga</h1>
    <div>
      <a href="/admin/oznake" class="btn btn-outline-secondary me-2">
        <i class="bi bi-arrow-left"></i> Nazad
      </a>
      <a href="/admin/oznake/izmena/<%= tag.id %>" class="btn btn-primary">
        <i class="bi bi-pencil"></i> Izmeni
      </a>
    </div>
  </div>

  <div class="row g-4">
    <!-- Osnovne informacije -->
    <div class="col-md-6">
      <div class="card h-100">
        <div class="card-header bg-light">
          <h5 class="mb-0">Osnovne informacije</h5>
        </div>
        <div class="card-body">
          <dl class="row mb-0">
            <dt class="col-sm-4">ID</dt>
            <dd class="col-sm-8"><%= tag.id %></dd>

            <dt class="col-sm-4">Naziv</dt>
            <dd class="col-sm-8"><%= tag.osnovno.naziv %></dd>

            <dt class="col-sm-4">Slug</dt>
            <dd class="col-sm-8"><%= tag.osnovno.slug %></dd>

            <dt class="col-sm-4">Domen</dt>
            <dd class="col-sm-8"><%= tag.osnovno.domen %></dd>

            <dt class="col-sm-4">Tip</dt>
            <dd class="col-sm-8"><%= tag.osnovno.tip %></dd>
          </dl>
        </div>
      </div>
    </div>

    <!-- Opis -->
    <div class="col-md-6">
      <div class="card h-100">
        <div class="card-header bg-light">
          <h5 class="mb-0">Opis</h5>
        </div>
        <div class="card-body">
          <dl class="row mb-0">
            <dt class="col-sm-4">Kratak opis</dt>
            <dd class="col-sm-8"><%= tag.opis.kratak || '—' %></dd>

            <dt class="col-sm-4">Dug opis</dt>
            <dd class="col-sm-8"><%= tag.opis.dug || '—' %></dd>
          </dl>
        </div>
      </div>
    </div>

    <!-- Meta podaci -->
    <div class="col-md-6">
      <div class="card h-100">
        <div class="card-header bg-light">
          <h5 class="mb-0">Meta podaci</h5>
        </div>
        <div class="card-body">
          <dl class="row mb-0">
            <dt class="col-sm-6">Indeksiranje</dt>
            <dd class="col-sm-6"><%= tag.meta.indeksiranje %></dd>

            <dt class="col-sm-6">Prioritet</dt>
            <dd class="col-sm-6"><%= tag.meta.prioritet %></dd>

            <dt class="col-sm-6">Aktivnost</dt>
            <dd class="col-sm-6"><%= tag.meta.aktivnost %></dd>
          </dl>
        </div>
      </div>
    </div>

    <!-- Vreme -->
    <div class="col-md-6">
      <div class="card h-100">
        <div class="card-header bg-light">
          <h5 class="mb-0">Vreme</h5>
        </div>
        <div class="card-body">
          <dl class="row mb-0">
            <dt class="col-sm-6">Kreiran</dt>
            <dd class="col-sm-6"><%= tag.vreme.kreiran %></dd>

            <dt class="col-sm-6">Ažuriran</dt>
            <dd class="col-sm-6"><%= tag.vreme.azuriran %></dd>
          </dl>
        </div>
      </div>
    </div>
  </div>
</div>

<%- include('../../includes/end') %>