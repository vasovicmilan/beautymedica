<%
  const { category, seo } = locals;
  if (!category) return;
%>

<%- include('../../includes/head', { seo }) %>
<%- include('../../includes/components/navigation') %>

<div class="container py-4">
  <div class="d-flex justify-content-between align-items-center mb-4">
    <h1 class="h2">Detalji kategorije</h1>
    <div>
      <a href="/admin/kategorije" class="btn btn-outline-secondary me-2">
        <i class="bi bi-arrow-left"></i> Nazad
      </a>
      <a href="/admin/kategorije/izmena/<%= category.id %>" class="btn btn-primary">
        <i class="bi bi-pencil"></i> Izmeni
      </a>
    </div>
  </div>

  <div class="row g-4">
    <!-- Osnovne informacije -->
    <div class="col-md-6">
      <div class="card h-100">
        <div class="card-header bg-light">
          <h5 class="mb-0">Osnovne informacije</h5>
        </div>
        <div class="card-body">
          <dl class="row mb-0">
            <dt class="col-sm-4">ID</dt>
            <dd class="col-sm-8"><%= category.id %></dd>

            <dt class="col-sm-4">Naziv</dt>
            <dd class="col-sm-8"><%= category.osnovno.naziv %></dd>

            <dt class="col-sm-4">Slug</dt>
            <dd class="col-sm-8"><%= category.osnovno.slug %></dd>

            <dt class="col-sm-4">Domen</dt>
            <dd class="col-sm-8"><%= category.osnovno.domen %></dd>

            <dt class="col-sm-4">Parent kategorija</dt>
            <dd class="col-sm-8"><%= category.osnovno.parent || '—' %></dd>

            <dt class="col-sm-4">Kratak opis</dt>
            <dd class="col-sm-8"><%= category.osnovno.kratakOpis || '—' %></dd>

            <dt class="col-sm-4">Dug opis</dt>
            <dd class="col-sm-8"><%= category.osnovno.dugOpis || '—' %></dd>
          </dl>
        </div>
      </div>
    </div>

    <!-- Slika -->
    <div class="col-md-6">
      <div class="card h-100">
        <div class="card-header bg-light">
          <h5 class="mb-0">Slika</h5>
        </div>
        <div class="card-body text-center">
          <% if (category.slika && category.slika.url) { %>
            <img src="<%= category.slika.url %>" alt="<%= category.slika.opis || category.osnovno.naziv %>" class="img-fluid rounded" style="max-height: 200px;">
            <p class="mt-2 text-muted"><%= category.slika.opis || 'Nema opisa slike' %></p>
          <% } else { %>
            <p class="text-muted">Nema slike</p>
          <% } %>
        </div>
      </div>
    </div>

    <!-- Meta podaci -->
    <div class="col-md-6">
      <div class="card h-100">
        <div class="card-header bg-light">
          <h5 class="mb-0">Meta podaci</h5>
        </div>
        <div class="card-body">
          <dl class="row mb-0">
            <dt class="col-sm-6">Indeksiranje</dt>
            <dd class="col-sm-6"><%= category.meta.indeksiranje %></dd>

            <dt class="col-sm-6">Prioritet</dt>
            <dd class="col-sm-6"><%= category.meta.prioritet %></dd>

            <dt class="col-sm-6">Aktivna</dt>
            <dd class="col-sm-6"><%= category.meta.aktivna %></dd>
          </dl>
        </div>
      </div>
    </div>

    <!-- Vreme -->
    <div class="col-md-6">
      <div class="card h-100">
        <div class="card-header bg-light">
          <h5 class="mb-0">Vreme</h5>
        </div>
        <div class="card-body">
          <dl class="row mb-0">
            <dt class="col-sm-6">Kreirano</dt>
            <dd class="col-sm-6"><%= category.vreme.kreirano %></dd>

            <dt class="col-sm-6">Ažurirano</dt>
            <dd class="col-sm-6"><%= category.vreme.azurirano %></dd>
          </dl>
        </div>
      </div>
    </div>
  </div>
</div>

<%- include('../../includes/end') %>