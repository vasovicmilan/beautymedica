<%
  const currentUrl = '/admin/oznake';
  const queryParams = { search, domain, type };
  const totalPages = Math.ceil(total / limit);
%>

<%- include('../../includes/head', { seo }) %>
<%- include('../../includes/components/navigation') %>

<div class="container py-4">
  <div class="d-flex justify-content-between align-items-center mb-4">
    <h1 class="h2">oznake</h1>
    <a href="/admin/oznake/dodavanje" class="btn btn-primary">
      <i class="bi bi-plus-circle"></i> Novi tag
    </a>
  </div>

  <!-- Search form -->
  <div class="card mb-4">
    <div class="card-body">
      <form action="/admin/oznake/pretraga" method="POST" class="row g-3">
        <div class="col-md-4">
          <label for="search" class="form-label">Pretraga</label>
          <input type="text" class="form-control" id="search" name="search" value="<%= search || '' %>" placeholder="Naziv, slug...">
        </div>
        <div class="col-md-3">
          <label for="domain" class="form-label">Domen</label>
          <select class="form-select" id="domain" name="domain">
            <option value="">Svi</option>
            <option value="service" <%= (domain === 'service') ? 'selected' : '' %>>Usluge</option>
            <option value="post" <%= (domain === 'post') ? 'selected' : '' %>>Blog</option>
          </select>
        </div>
        <div class="col-md-3">
          <label for="type" class="form-label">Tip</label>
          <select class="form-select" id="type" name="type">
            <option value="">Svi</option>
            <option value="body_part" <%= (type === 'body_part') ? 'selected' : '' %>>Deo tela</option>
            <option value="goal" <%= (type === 'goal') ? 'selected' : '' %>>Cilj</option>
            <option value="technology" <%= (type === 'technology') ? 'selected' : '' %>>Tehnologija</option>
            <option value="intensity" <%= (type === 'intensity') ? 'selected' : '' %>>Intenzitet</option>
            <option value="duration" <%= (type === 'duration') ? 'selected' : '' %>>Trajanje</option>
            <option value="custom" <%= (type === 'custom') ? 'selected' : '' %>>Prilagođeno</option>
          </select>
        </div>
        <div class="col-md-2 d-flex align-items-end">
          <button type="submit" class="btn btn-primary w-100">Pretraži</button>
        </div>
        <input type="hidden" name="CSRFToken" value="<%= csrfToken %>">
      </form>
    </div>
  </div>

  <!-- Tabela -->
  <div class="card">
    <div class="card-body p-0">
      <%- include('../../includes/components/table', {
        items: tags,
        actions: [
          { type: 'link', url: '/admin/oznake/detalji/', icon: 'bi-eye', color: 'outline-info', ariaLabel: 'Detalji' },
          { type: 'link', url: '/admin/oznake/izmena/', icon: 'bi-pencil', color: 'outline-secondary', ariaLabel: 'Izmena' },
          { type: 'form', formAction: '/admin/oznake/brisanje/', icon: 'bi-trash', color: 'outline-danger', ariaLabel: 'Brisanje', confirm: 'Da li ste sigurni da želite da obrišete ovaj tag?' }
        ]
      }) %>
    </div>
  </div>

  <!-- Paginacija -->
  <% if (totalPages > 1) { %>
    <%- include('../../includes/components/pagination', {
      currentPage: page,
      totalPages: totalPages,
      baseUrl: currentUrl,
      queryParams: queryParams
    }) %>
  <% } %>
</div>

<%- include('../../includes/end') %>