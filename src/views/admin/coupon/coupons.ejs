<%
  const currentUrl = '/admin/kuponi';
  const queryParams = { search };
  const totalPages = Math.ceil(total / limit);
%>

<%- include('../../includes/head', { seo }) %>
<%- include('../../includes/components/navigation') %>

<div class="container py-4">
  <div class="d-flex justify-content-between align-items-center mb-4">
    <h1 class="h2">Kuponi</h1>
    <a href="/admin/kuponi/dodavanje" class="btn btn-primary">
      <i class="bi bi-plus-circle"></i> Novi kupon
    </a>
  </div>

  <!-- Search form -->
  <div class="card mb-4">
    <div class="card-body">
      <form action="/admin/kuponi/pretraga" method="POST" class="row g-3">
        <div class="col-md-8">
          <label for="search" class="form-label">Pretraga po kodu</label>
          <input type="text" class="form-control" id="search" name="search" value="<%= search || '' %>" placeholder="Npr. WELCOME10">
        </div>
        <div class="col-md-4 d-flex align-items-end">
          <button type="submit" class="btn btn-primary w-100">Pretraži</button>
        </div>
        <input type="hidden" name="CSRFToken" value="<%= csrfToken %>">
      </form>
    </div>
  </div>

  <!-- Tabela -->
  <div class="card">
    <div class="card-body p-0">
      <%- include('../../includes/components/table', {
        columns: [
          { key: 'id', label: 'ID' },
          { key: 'kod', label: 'Kod' },
          { key: 'tip', label: 'Tip' },
          { key: 'popust', label: 'Popust' },
          { key: 'maxUpotreba', label: 'Max upotreba' },
          { key: 'iskorišćeno', label: 'Iskorišćeno' },
          { key: 'aktivnost', label: 'Aktivnost' },
          { key: 'važiOd', label: 'Važi od' },
          { key: 'važiDo', label: 'Važi do' },
          { key: 'kreiran', label: 'Kreiran' }
        ],
        items: coupons,
        actions: [
          { type: 'link', url: '/admin/kuponi/detalji/', icon: 'bi-eye', color: 'outline-info', ariaLabel: 'Detalji' },
          { type: 'link', url: '/admin/kuponi/izmena/', icon: 'bi-pencil', color: 'outline-secondary', ariaLabel: 'Izmena' },
          { type: 'form', formAction: '/admin/kuponi/brisanje', icon: 'bi-trash', color: 'outline-danger', ariaLabel: 'Brisanje', confirm: 'Da li ste sigurni da želite da obrišete ovaj kupon?' }
        ]
      }) %>
    </div>
  </div>

  <!-- Paginacija -->
  <% if (totalPages > 1) { %>
    <%- include('../../includes/components/pagination', {
      currentPage: page,
      totalPages: totalPages,
      baseUrl: currentUrl,
      queryParams: queryParams
    }) %>
  <% } %>
</div>

<%- include('../../includes/end') %>