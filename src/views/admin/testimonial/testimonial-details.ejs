<%
  if (!testimonial) return;
  const isApproved = testimonial.odobren === 'Odobreno';
%>

<%- include('../../includes/head', { seo }) %>
<%- include('../../includes/components/navigation') %>

<div class="container py-4">
  <div class="d-flex justify-content-between align-items-center mb-4">
    <h1 class="h2">Detalji utiska</h1>
    <div>
      <a href="/admin/utisci" class="btn btn-outline-secondary me-2">
        <i class="bi bi-arrow-left"></i> Nazad
      </a>
    </div>
  </div>

  <div class="row g-4">
    <!-- Osnovne informacije (samo prikaz) -->
    <div class="col-md-6">
      <div class="card h-100">
        <div class="card-header bg-light">
          <h5 class="mb-0">Osnovne informacije</h5>
        </div>
        <div class="card-body">
          <dl class="row mb-0">
            <dt class="col-sm-4">ID</dt>
            <dd class="col-sm-8"><%= testimonial.id %></dd>
            <dt class="col-sm-4">Autor</dt>
            <dd class="col-sm-8"><%= testimonial.autor.ime %></dd>
            <dt class="col-sm-4">Email</dt>
            <dd class="col-sm-8"><%= testimonial.autor.email || '—' %></dd>
            <dt class="col-sm-4">Ocena</dt>
            <dd class="col-sm-8"><%= testimonial.ocena %> ★</dd>
            <dt class="col-sm-4">Odobren</dt>
            <dd class="col-sm-8"><%= testimonial.odobren %></dd>
          </dl>
        </div>
      </div>
    </div>

    <div class="col-md-6">
      <div class="card h-100">
        <div class="card-header bg-light">
          <h5 class="mb-0">Vreme</h5>
        </div>
        <div class="card-body">
          <dl class="row mb-0">
            <dt class="col-sm-6">Kreiran</dt>
            <dd class="col-sm-6"><%= testimonial.vreme.kreiran %></dd>
            <dt class="col-sm-6">Ažuriran</dt>
            <dd class="col-sm-6"><%= testimonial.vreme.azuriran %></dd>
          </dl>
        </div>
      </div>
    </div>

    <div class="col-12">
      <div class="card">
        <div class="card-header bg-light">
          <h5 class="mb-0">Komentar</h5>
        </div>
        <div class="card-body">
          <p class="mb-0"><%= testimonial.komentar %></p>
        </div>
      </div>
    </div>

    <!-- Jednostavna forma za odobravanje / odbijanje -->
    <div class="col-12">
      <div class="card">
        <div class="card-header bg-light">
          <h5 class="mb-0">Promena statusa odobrenja</h5>
        </div>
        <div class="card-body text-center">
          <form action="/admin/utisci/izmena" method="POST" class="d-inline">
            <input type="hidden" name="_method" value="PUT">
            <input type="hidden" name="id" value="<%= testimonial.id %>">
            <input type="hidden" name="CSRFToken" value="<%= csrfToken %>">
            <input type="hidden" name="approved" value="<%= !isApproved %>">
            <button type="submit" class="btn btn-lg <%= isApproved ? 'btn-warning' : 'btn-success' %>">
              <%= isApproved ? 'Odbij utisak' : 'Odobri utisak' %>
            </button>
          </form>
          <p class="mt-3 text-muted">
            <%= isApproved ? 'Utisak je trenutno odobren. Klikom na dugme će biti uklonjen sa sajta.' : 'Utisak nije odobren. Klikom na dugme će postati vidljiv na sajtu.' %>
          </p>
        </div>
      </div>
    </div>
  </div>
</div>

<%- include('../../includes/end') %>