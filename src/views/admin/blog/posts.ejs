<%
  const currentUrl = '/admin/objave';
  const queryParams = { search, status };
  const totalPages = Math.ceil(total / limit);
%>

<%- include('../../includes/head', { seo }) %>
<%- include('../../includes/components/navigation') %>

<div class="container py-4">
  <div class="d-flex justify-content-between align-items-center mb-4">
    <h1 class="h2">Blog postovi</h1>
    <a href="/admin/objave/dodavanje" class="btn btn-primary">
      <i class="bi bi-plus-circle"></i> Novi post
    </a>
  </div>

  <!-- Search form -->
  <div class="card mb-4">
    <div class="card-body">
      <form action="/admin/objave/pretraga" method="POST" class="row g-3">
        <div class="col-md-4">
          <label for="search" class="form-label">Pretraga</label>
          <input type="text" class="form-control" id="search" name="search" value="<%= search || '' %>" placeholder="Naslov, slug...">
        </div>
        <div class="col-md-3">
          <label for="status" class="form-label">Status</label>
          <select class="form-select" id="status" name="status">
            <option value="">Svi</option>
            <option value="draft" <%= status === 'draft' ? 'selected' : '' %>>Nacrt</option>
            <option value="published" <%= status === 'published' ? 'selected' : '' %>>Objavljeno</option>
            <option value="featured" <%= status === 'featured' ? 'selected' : '' %>>Istaknuto</option>
          </select>
        </div>
        <div class="col-md-2">
          <label for="limit" class="form-label">Prikaz po stranici</label>
          <select class="form-select" id="limit" name="limit">
            <option value="10">10</option>
            <option value="20" selected>20</option>
            <option value="50">50</option>
          </select>
        </div>
        <div class="col-md-3 d-flex align-items-end">
          <button type="submit" class="btn btn-primary w-100">Pretraži</button>
        </div>
        <input type="hidden" name="CSRFToken" value="<%= csrfToken %>">
      </form>
    </div>
  </div>

  <!-- Tabela -->
  <div class="card">
    <div class="card-body p-0">
      <%- include('../../includes/components/table', {
        columns: [
          { key: 'id', label: 'ID' },
          { key: 'naslov', label: 'Naslov' },
          { key: 'slug', label: 'Slug' },
          { key: 'status', label: 'Status' },
          { key: 'autor', label: 'Autor' },
          { key: 'datumObjave', label: 'Datum objave' },
          { key: 'indeksiranje', label: 'Indeksiranje' }
        ],
        items: posts,
        actions: [
          { type: 'link', url: '/admin/objave/detalji/', icon: 'bi-eye', color: 'outline-info', ariaLabel: 'Detalji' },
          { type: 'link', url: '/admin/objave/izmena/', icon: 'bi-pencil', color: 'outline-secondary', ariaLabel: 'Izmena' },
          { type: 'form', formAction: '/admin/objave/brisanje', icon: 'bi-trash', color: 'outline-danger', ariaLabel: 'Brisanje', confirm: 'Da li ste sigurni da želite da obrišete ovaj post?' }
        ]
      }) %>
    </div>
  </div>

  <!-- Paginacija -->
  <% if (totalPages > 1) { %>
    <%- include('../../includes/components/pagination', {
      currentPage: page,
      totalPages: totalPages,
      baseUrl: currentUrl,
      queryParams: queryParams
    }) %>
  <% } %>
</div>

<%- include('../../includes/end') %>