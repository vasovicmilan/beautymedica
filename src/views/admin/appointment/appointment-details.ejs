<%
  if (!appointment) return;
%>

<%- include('../../includes/head', { seo }) %>
<%- include('../../includes/components/navigation') %>

<div class="container py-4">
  <div class="d-flex justify-content-between align-items-center mb-4">
    <h1 class="h2">Detalji termina</h1>
    <div>
      <a href="/admin/termini" class="btn btn-outline-secondary me-2">
        <i class="bi bi-arrow-left"></i> Nazad
      </a>
      <a href="/admin/termini/izmena/<%= appointment.id %>" class="btn btn-primary">
        <i class="bi bi-pencil"></i> Izmeni
      </a>
    </div>
  </div>

  <div class="row g-4">
    <div class="col-md-6">
      <div class="card h-100">
        <div class="card-header bg-light"><h5>Korisnik</h5></div>
        <div class="card-body">
          <dl class="row">
            <dt class="col-sm-4">Ime</dt><dd class="col-sm-8"><%= appointment.korisnik.ime %></dd>
            <dt class="col-sm-4">Email</dt><dd class="col-sm-8"><%= appointment.korisnik.email || '—' %></dd>
            <dt class="col-sm-4">Telefon</dt><dd class="col-sm-8"><%= appointment.korisnik.telefon || '—' %></dd>
          </dl>
        </div>
      </div>
    </div>
    <div class="col-md-6">
      <div class="card h-100">
        <div class="card-header bg-light"><h5>Usluga</h5></div>
        <div class="card-body">
          <dl class="row">
            <dt class="col-sm-4">Naziv</dt><dd class="col-sm-8"><%= appointment.usluga.naziv %></dd>
            <dt class="col-sm-4">Trajanje</dt><dd class="col-sm-8"><%= appointment.usluga.trajanje || '—' %></dd>
            <dt class="col-sm-4">Cena</dt><dd class="col-sm-8"><%= appointment.usluga.cena %></dd>
          </dl>
        </div>
      </div>
    </div>
    <div class="col-md-6">
      <div class="card h-100">
        <div class="card-header bg-light"><h5>Termin</h5></div>
        <div class="card-body">
          <dl class="row">
            <dt class="col-sm-4">Početak</dt><dd class="col-sm-8"><%= appointment.termin.pocetak %></dd>
            <dt class="col-sm-4">Kraj</dt><dd class="col-sm-8"><%= appointment.termin.kraj %></dd>
          </dl>
        </div>
      </div>
    </div>
    <div class="col-md-6">
      <div class="card h-100">
        <div class="card-header bg-light"><h5>Status i cena</h5></div>
        <div class="card-body">
          <dl class="row">
            <dt class="col-sm-4">Status</dt><dd class="col-sm-8"><%= appointment.status %></dd>
            <dt class="col-sm-4">Popust</dt><dd class="col-sm-8"><%= appointment.popust || '0 RSD' %></dd>
            <dt class="col-sm-4">Konačna cena</dt><dd class="col-sm-8"><%= appointment.konacnaCena %></dd>
            <dt class="col-sm-4">Kupon</dt><dd class="col-sm-8"><%= appointment.kupon || '—' %></dd>
          </dl>
        </div>
      </div>
    </div>
    <div class="col-md-6">
      <div class="card h-100">
        <div class="card-header bg-light"><h5>Terapeut</h5></div>
        <div class="card-body">
          <dl class="row">
            <dt class="col-sm-4">Odabrani terapeut</dt><dd class="col-sm-8"><%= appointment.terapeut || '—' %></dd>
            <dt class="col-sm-4">Dodeljeni terapeut</dt><dd class="col-sm-8"><%= appointment.dodeljenTerapeut || '—' %></dd>
          </dl>
        </div>
      </div>
    </div>
    <div class="col-md-6">
      <div class="card h-100">
        <div class="card-header bg-light"><h5>Log akcija</h5></div>
        <div class="card-body">
          <dl class="row">
            <dt class="col-sm-5">Odbio</dt><dd class="col-sm-7"><%= appointment.odbio || '—' %></dd>
            <dt class="col-sm-5">Odbijen u</dt><dd class="col-sm-7"><%= appointment.odbijenU || '—' %></dd>
            <dt class="col-sm-5">Razlog odbijanja</dt><dd class="col-sm-7"><%= appointment.razlogOdbijanja || '—' %></dd>
            <dt class="col-sm-5">Potvrdio</dt><dd class="col-sm-7"><%= appointment.potvrdio || '—' %></dd>
            <dt class="col-sm-5">Potvrđen u</dt><dd class="col-sm-7"><%= appointment.potvrdjenU || '—' %></dd>
            <dt class="col-sm-5">Dodelio</dt><dd class="col-sm-7"><%= appointment.dodelio || '—' %></dd>
            <dt class="col-sm-5">Dodeljen u</dt><dd class="col-sm-7"><%= appointment.dodeljenU || '—' %></dd>
          </dl>
        </div>
      </div>
    </div>
    <div class="col-12">
      <div class="card">
        <div class="card-header bg-light"><h5>Napomena korisnika</h5></div>
        <div class="card-body"><%= appointment.napomena || '—' %></div>
      </div>
    </div>
    <div class="col-12">
      <div class="card">
        <div class="card-header bg-light"><h5>Vremenske oznake</h5></div>
        <div class="card-body">
          <dl class="row">
            <dt class="col-sm-2">Kreiran</dt><dd class="col-sm-4"><%= appointment.createdAt %></dd>
            <dt class="col-sm-2">Ažuriran</dt><dd class="col-sm-4"><%= appointment.updatedAt %></dd>
          </dl>
        </div>
      </div>
    </div>
  </div>
</div>

<%- include('../../includes/end') %>